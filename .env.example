NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Server-side import only. Never expose this in NEXT_PUBLIC_* variables.
DATABASE_URL=postgresql://postgres:YOUR_DATABASE_PASSWORD@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
OPENPOWERLIFTING_SOURCE=openipf
OPENPOWERLIFTING_LIMIT=10000
